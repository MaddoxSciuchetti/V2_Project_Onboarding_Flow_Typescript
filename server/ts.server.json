{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "outDir": "./built",
        "rootDir": "./",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "allowImportingTsExtensions": false
    },
    "scripts": {
        "build": "tsc -p tsconfig.server.json",
        "start": "node ./built/server.js"
    },

    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
