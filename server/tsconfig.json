{
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "esnext"],
        "target": "es2015",
        "outDir": "./built",
        "rootDir": ".",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowJs": true,
        "resolveJsonModule": true,
        "noImplicitAny": false,
        "forceConsistentCasingInFileNames": true,
        "strict": true,

        "strictNullChecks": true,
        "strictFunctionTypes": true,

        "paths": {
            "@/*": ["./src/*"],
            "@/lib/*": ["./src/lib/*"],
            "@/generated/*": ["./generated/*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        "src/createApp.ts"
    ],
    "exclude": ["node_modules"]
}
