generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

/// Org-wide membership: admin (full access) or worker (default).
enum OrgMemberRole {
  admin
  worker
}

/// Scope for rows in `organization_statuses` (and FK targets on engagements vs issues).
enum StatusEntityKind {
  engagement
  issue
}

// ============================================================
// AUTH & USER
// ============================================================

model User {
  id                     String               @id @default(uuid())
  firstName              String               @map("first_name")
  lastName               String               @map("last_name")
  displayName            String?              @map("display_name")
  email                  String               @unique @db.Citext
  passwordHash           String               @map("password_hash")
  avatarUrl              String?              @map("avatar_url")
  phoneNumber            String?              @map("phone_number")
  phoneVerified          Boolean              @default(false) @map("phone_verified")
  isEmailVerified        Boolean              @default(false) @map("is_email_verified")
  status                 UserStatus           @default(active)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  refreshTokens          RefreshToken[]
  verificationCodes      NewVerificationCode[]
  organizationMembers    OrganizationMember[]
  sentInvitations        Invitation[]          @relation("InvitedBy")
  createdWorkers         Worker[]              @relation("WorkerCreatedBy")
  uploadedDocuments      WorkerDocument[]
  responsibleEngagements WorkerEngagement[]
  createdIssues          Issue[]               @relation("IssueCreatedBy")
  assignedIssues         Issue[]               @relation("IssueAssignedTo")
  issueAuditLogs         IssueAuditLog[]
  comments               Comment[]
  createdTemplates       IssueTemplate[]
  createdOrganizations   Organization[]
  absences               Absence[]             @relation("UserAbsences")
  substitutingFor        Absence[]             @relation("SubstituteAbsences")

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  deviceName String?   @map("device_name")
  deviceType String?   @map("device_type")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model NewVerificationCode {
  id        String               @id @default(uuid())
  userId    String               @map("user_id")
  type      VerificationCodeType
  expiresAt DateTime             @map("expires_at") @db.Timestamptz()
  usedAt    DateTime?            @map("used_at") @db.Timestamptz()
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("new_verification_codes")
}

// ============================================================
// ORGANIZATION
// ============================================================

model Organization {
  id              String                 @id @default(uuid())
  createdByUserId String?                @map("created_by_user_id")
  name            String
  slug            String                 @unique
  logoUrl         String?                @map("logo_url")
  description     String?
  email           String?
  phoneNumber     String?                @map("phone_number")
  websiteUrl      String?                @map("website_url")
  country         String?
  timezone        String?
  language        String?
  industry        String?
  size            OrganizationSize?
  status          OrganizationStatusEnum @default(active)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  createdBy       User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  members         OrganizationMember[]
  workers         Worker[]
  invitations     Invitation[]
  issueTemplates  IssueTemplate[]
  engagements     WorkerEngagement[]
  statuses        OrganizationStatus[]   @relation("OrgStatuses")
  subscription    Subscription?
  absences        Absence[]


  @@map("organizations")
}

model OrganizationMember {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  organizationId String         @map("organization_id")
  membershipRole OrgMemberRole  @default(worker) @map("membership_role")
  status         MemberStatus   @default(active)
  joinedAt       DateTime?      @map("joined_at") @db.Timestamptz()
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

model OrganizationStatus {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  entityType     StatusEntityKind  @map("entity_type")
  name           String
  color          String?
  orderIndex     Int               @default(0) @map("order_index")
  isDefault      Boolean           @default(false) @map("is_default")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization   Organization       @relation("OrgStatuses", fields: [organizationId], references: [id], onDelete: Cascade)
  engagements    WorkerEngagement[] @relation("OrgStatusEngagements")
  issues         Issue[]            @relation("OrgStatusIssues")

  @@unique([organizationId, entityType, name])
  /// Anchor for composite FK from WorkerEngagement + Issue (status_id + status_entity_type).
  @@unique([id, entityType])
  @@index([organizationId])
  @@map("organization_statuses")
}

// ============================================================
// INVITATIONS
// ============================================================

model Invitation {
  id                     String           @id @default(uuid())
  organizationId         String           @map("organization_id")
  invitedByUserId        String           @map("invited_by_user_id")
  invitedMembershipRole  OrgMemberRole    @default(worker) @map("invited_membership_role")
  email                  String           @db.Citext
  tokenHash              String           @unique @map("token_hash")
  status                 InvitationStatus @default(pending)
  expiresAt              DateTime         @map("expires_at") @db.Timestamptz()
  acceptedAt             DateTime?        @map("accepted_at") @db.Timestamptz()
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  organization           Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy              User             @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

// ============================================================
// WORKER
// ============================================================

model Worker {
  id               String             @id @default(uuid())
  organizationId   String             @map("organization_id")
  createdByUserId  String             @map("created_by_user_id")
  firstName        String             @map("first_name")
  lastName         String             @map("last_name")
  email            String             @db.Citext
  phoneNumber      String?            @map("phone_number")
  birthday         DateTime?          @db.Date
  position         String?
  street           String?
  city             String?
  state            String?
  postalCode       String?            @map("postal_code")
  country          String?
  entryDate        DateTime?          @map("entry_date") @db.Date
  exitDate         DateTime?          @map("exit_date") @db.Date
  status           WorkerStatus       @default(active)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User               @relation("WorkerCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  documents        WorkerDocument[]
  engagements      WorkerEngagement[]

  @@index([organizationId])
  @@index([email])
  @@map("workers")
}

model WorkerDocument {
  id               String              @id @default(uuid())
  workerId         String              @map("worker_id")
  uploadedByUserId String              @map("uploaded_by_user_id")
  name             String
  fileUrl          String              @map("file_url")
  fileType         DocumentFileType    @map("file_type")
  fileSizeBytes    Int?                @map("file_size_bytes")
  mimeType         String?             @map("mime_type")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  worker           Worker              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  uploadedBy       User                @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([workerId])
  @@map("worker_documents")
}

// ============================================================
// WORKER ENGAGEMENT
// ============================================================

model WorkerEngagement {
  id                String             @id @default(uuid())
  workerId          String             @map("worker_id")
  organizationId    String             @map("organization_id")
  responsibleUserId String             @map("responsible_user_id")
  statusId          String             @map("status_id")
  /// Always `engagement`; DB CHECK + FK guarantee valid pairing with `organization_statuses`.
  statusEntityType  StatusEntityKind   @default(engagement) @map("status_entity_type")
  type              EngagementType
  startDate         DateTime?          @map("start_date") @db.Date
  endDate           DateTime?          @map("end_date") @db.Date
  completedAt       DateTime?          @map("completed_at") @db.Timestamptz()
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  worker            Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responsibleUser   User               @relation(fields: [responsibleUserId], references: [id], onDelete: Restrict)
  engagementStatus  OrganizationStatus @relation("OrgStatusEngagements", fields: [statusId, statusEntityType], references: [id, entityType], onDelete: Restrict)
  issues            Issue[]

  @@index([workerId])
  @@index([organizationId])
  @@index([statusId])
  @@index([statusEntityType])
  @@map("worker_engagements")
}

// ============================================================
// ISSUE TEMPLATES
// ============================================================

model IssueTemplate {
  id              String                 @id @default(uuid())
  organizationId  String                 @map("organization_id")
  createdByUserId String                 @map("created_by_user_id")
  name            String                 @map("template_name")
  description     String?                @map("template_description")
  isActive        Boolean                @default(true) @map("is_active")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       User                   @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items           TemplateItem[]

  @@index([organizationId])
  @@map("issue_templates")
}

model TemplateItem {
  id              String             @id @default(uuid())
  issueTemplateId String             @map("issue_template_id")
  title           String
  description     String?
  defaultPriority IssuePriority?     @map("default_priority")
  orderIndex      Int                @default(0) @map("order_index")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  issueTemplate   IssueTemplate      @relation(fields: [issueTemplateId], references: [id], onDelete: Cascade)
  issues          Issue[]

  @@index([issueTemplateId])
  @@map("template_items")
}

// ============================================================
// ISSUES
// ============================================================

model Issue {
  id                 String             @id @default(uuid())
  workerEngagementId String             @map("worker_engagement_id")
  createdByUserId    String             @map("created_by_user_id")
  assigneeUserId     String?            @map("assignee_user_id")
  templateItemId     String?            @map("template_item_id")
  statusId           String             @map("status_id")
  /// Always `issue`; DB CHECK + FK guarantee valid pairing with `organization_statuses`.
  statusEntityType   StatusEntityKind   @default(issue) @map("status_entity_type")
  title              String
  description        String?
  priority           IssuePriority      @default(no_priority)
  dueDate            DateTime?          @map("due_date") @db.Date
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  workerEngagement   WorkerEngagement   @relation(fields: [workerEngagementId], references: [id], onDelete: Cascade)
  createdBy          User               @relation("IssueCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignee           User?              @relation("IssueAssignedTo", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  templateItem       TemplateItem?      @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  issueStatus        OrganizationStatus @relation("OrgStatusIssues", fields: [statusId, statusEntityType], references: [id, entityType], onDelete: Restrict)
  comments           Comment[]
  auditLogs          IssueAuditLog[]

  @@index([workerEngagementId])
  @@index([assigneeUserId])
  @@index([statusId])
  @@index([statusEntityType])
  @@map("issues")
}

model IssueAuditLog {
  id          String   @id @default(uuid())
  issueId     String   @map("issue_id")
  actorUserId String   @map("actor_user_id")
  action      String
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorUser   User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([issueId])
  @@map("issue_audit_logs")
}

model Comment {
  id              String    @id @default(uuid())
  issueId         String    @map("issue_id")
  userId          String    @map("user_id")
  parentCommentId String?   @map("parent_comment_id")
  body            String
  editedAt        DateTime? @map("edited_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  issue           Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentReplies")

  @@index([issueId])
  @@index([parentCommentId])
  @@map("comments")
}

// ============================================================
// SUBSCRIPTION & BILLING
// ============================================================

model Subscription {
  id                      String             @id @default(uuid())
  organizationId        String               @unique @map("organization_id")
  plan                    SubscriptionPlan   @default(free)
  status                  SubscriptionStatus @default(trialing)
  trialEndsAt             DateTime?          @map("trial_ends_at") @db.Timestamptz()
  currentPeriodStart      DateTime?          @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd        DateTime?          @map("current_period_end") @db.Timestamptz()
  provider                String?
  providerPaymentMethodId String?          @map("provider_payment_method_id")
  cardBrand               String?          @map("card_brand")
  cardLast4               String?          @map("card_last4") @db.Char(4)
  cardExpMonth            Int?             @map("card_exp_month") @db.SmallInt
  cardExpYear             Int?             @map("card_exp_year") @db.SmallInt
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization            Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices                Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id                String        @id @default(uuid())
  subscriptionId    String        @map("subscription_id")
  providerInvoiceId String?       @map("provider_invoice_id")
  amountCents       Int           @map("amount_cents")
  currency          String        @default("USD")
  status            InvoiceStatus @default(draft)
  invoicePdfUrl     String?       @map("invoice_pdf_url")
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz()
  dueDate           DateTime?     @map("due_date") @db.Date
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
  @@map("invoices")
}

model Absence {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  orgId        String      @map("org_id")
  absenceType  AbsenceType @map("absence_type")
  startDate    DateTime    @map("start_date") @db.Timestamptz()
  endDate      DateTime    @map("end_date") @db.Timestamptz()
  substituteId String?     @map("substitute_id")

  user         User         @relation("UserAbsences", fields: [userId], references: [id])
  substitute   User?        @relation("SubstituteAbsences", fields: [substituteId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([userId])
  @@index([orgId])
  @@map("absences")
}



// ENUMS

enum AbsenceType {
    SICK
    VACATION
    PARENTAL_LEAVE
    UNPAID
    OTHER
}

enum UserStatus {
  active
  inactive
  suspended
}

enum OrganizationSize {
  size_1_10     @map("1-10")
  size_11_50    @map("11-50")
  size_51_200   @map("51-200")
  size_201_500  @map("201-500")
  size_500_plus @map("500+")
}

enum OrganizationStatusEnum {
  active
  suspended
  deleted
}

enum MemberStatus {
  active
  inactive
  suspended
}

enum VerificationCodeType {
  email_verify
  password_reset
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum WorkerStatus {
  active
  inactive
}

enum DocumentFileType {
  contract
  id
  certificate
  other
}

enum EngagementType {
  onboarding
  offboarding
  transfer
}

enum IssuePriority {
  urgent
  high
  medium
  low
  no_priority
}

enum SubscriptionPlan {
  free
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

