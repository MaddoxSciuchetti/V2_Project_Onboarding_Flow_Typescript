generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

// New Phyiscal Data Model


// ============================================================
// AUTH & USER
// ============================================================

model NewUser {
  id                     String               @id @default(uuid())
  firstName              String               @map("first_name")
  lastName               String               @map("last_name")
  displayName            String?              @map("display_name")
  email                  String               @unique @db.Citext
  passwordHash           String               @map("password_hash")
  avatarUrl              String?              @map("avatar_url")
  phoneNumber            String?              @map("phone_number")
  phoneVerified          Boolean              @default(false) @map("phone_verified")
  isEmailVerified        Boolean              @default(false) @map("is_email_verified")
  status                 UserStatus           @default(active)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  refreshTokens          RefreshToken[]
  verificationCodes      NewVerificationCode[]
  organizationMembers    OrganizationMember[]
  sentInvitations        Invitation[]          @relation("InvitedBy")
  createdWorkers         Worker[]              @relation("WorkerCreatedBy")
  archivedWorkers        Worker[]              @relation("WorkerArchivedBy")
  uploadedDocuments      WorkerDocument[]
  documentLogs           WorkerDocumentLog[]
  responsibleEngagements WorkerEngagement[]
  workerAuditLogs        WorkerAuditLog[]
  createdIssues          Issue[]               @relation("IssueCreatedBy")
  assignedIssues         Issue[]               @relation("IssueAssignedTo")
  issueAuditLogs         IssueAuditLog[]
  comments               Comment[]
  notifications          Notification[]
  createdTemplates       IssueTemplate[]
  createdRoles           Role[]
  createdOrganizations   Organization[]

  @@map("new_users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  deviceName String?   @map("device_name")
  deviceType String?   @map("device_type")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  user       NewUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model NewVerificationCode {
  id        String               @id @default(uuid())
  userId    String               @map("user_id")
  type      VerificationCodeType
  expiresAt DateTime             @map("expires_at") @db.Timestamptz()
  usedAt    DateTime?            @map("used_at") @db.Timestamptz()
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  user      NewUser              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("new_verification_codes")
}

// ============================================================
// ORGANIZATION
// ============================================================

model Organization {
  id              String                 @id @default(uuid())
  createdByUserId String?                @map("created_by_user_id")
  name            String
  slug            String                 @unique
  logoUrl         String?                @map("logo_url")
  description     String?
  email           String?
  phoneNumber     String?                @map("phone_number")
  websiteUrl      String?                @map("website_url")
  country         String?
  timezone        String?
  language        String?
  industry        String?
  size            OrganizationSize?
  status          OrganizationStatusEnum @default(active)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  createdBy       NewUser?               @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  members         OrganizationMember[]
  roles           Role[]
  workers         Worker[]
  invitations     Invitation[]
  issueTemplates  IssueTemplate[]
  engagements     WorkerEngagement[]
  notifications   Notification[]
  statuses        OrganizationStatus[]   @relation("OrgStatuses")
  labels          Label[]
  subscription    Subscription?

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  organizationId String       @map("organization_id")
  roleId         String       @map("role_id")
  status         MemberStatus @default(active)
  joinedAt       DateTime?    @map("joined_at") @db.Timestamptz()
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  user           NewUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

model OrganizationStatus {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  entityType     String       @map("entity_type")
  name           String
  color          String?
  orderIndex     Int          @default(0) @map("order_index")
  isDefault      Boolean      @default(false) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization   Organization       @relation("OrgStatuses", fields: [organizationId], references: [id], onDelete: Cascade)
  engagements    WorkerEngagement[]
  issues         Issue[]

  @@unique([organizationId, entityType, name])
  @@index([organizationId])
  @@map("organization_statuses")
}

model Label {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  color          String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  issueLabels    IssueLabel[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("labels")
}

// ============================================================
// ROLES & PERMISSIONS
// ============================================================

model Role {
  id              String               @id @default(uuid())
  organizationId  String               @map("organization_id")
  createdByUserId String?              @map("created_by_user_id")
  name            String
  description     String?
  isSystem        Boolean              @default(false) @map("is_system")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       NewUser?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  permissions     RolePermission[]
  members         OrganizationMember[]
  invitations     Invitation[]

  @@index([organizationId])
  @@map("roles")
}

model RolePermission {
  id              String              @id @default(uuid())
  roleId          String              @map("role_id")
  permissionId    String              @map("permission_id")
  createdByUserId String?             @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  role            Role                @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      PermissionCatalogue @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

model PermissionCatalogue {
  id              String           @id @default(uuid())
  key             String           @unique
  group           String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  rolePermissions RolePermission[]

  @@map("permission_catalogue")
}

// ============================================================
// INVITATIONS
// ============================================================

model Invitation {
  id              String           @id @default(uuid())
  organizationId  String           @map("organization_id")
  invitedByUserId String           @map("invited_by_user_id")
  roleId          String           @map("role_id")
  email           String           @db.Citext
  tokenHash       String           @unique @map("token_hash")
  status          InvitationStatus @default(pending)
  expiresAt       DateTime         @map("expires_at") @db.Timestamptz()
  acceptedAt      DateTime?        @map("accepted_at") @db.Timestamptz()
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy       NewUser          @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  role            Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([email])
  @@map("invitations")
}

// ============================================================
// WORKER
// ============================================================

model Worker {
  id               String             @id @default(uuid())
  organizationId   String             @map("organization_id")
  createdByUserId  String             @map("created_by_user_id")
  archivedByUserId String?            @map("archived_by_user_id")
  firstName        String             @map("first_name")
  lastName         String             @map("last_name")
  email            String             @db.Citext
  phoneNumber      String?            @map("phone_number")
  birthday         DateTime?          @db.Date
  position         String?
  street           String?
  city             String?
  state            String?
  postalCode       String?            @map("postal_code")
  country          String?
  entryDate        DateTime?          @map("entry_date") @db.Date
  exitDate         DateTime?          @map("exit_date") @db.Date
  status           WorkerStatus       @default(active)
  archivedAt       DateTime?          @map("archived_at") @db.Timestamptz()
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        NewUser            @relation("WorkerCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  archivedBy       NewUser?           @relation("WorkerArchivedBy", fields: [archivedByUserId], references: [id], onDelete: SetNull)
  documents        WorkerDocument[]
  engagements      WorkerEngagement[]

  @@index([organizationId])
  @@index([email])
  @@map("workers")
}

model WorkerDocument {
  id               String              @id @default(uuid())
  workerId         String              @map("worker_id")
  uploadedByUserId String              @map("uploaded_by_user_id")
  name             String
  fileUrl          String              @map("file_url")
  fileType         DocumentFileType    @map("file_type")
  fileSizeBytes    Int?                @map("file_size_bytes")
  mimeType         String?             @map("mime_type")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  worker           Worker              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  uploadedBy       NewUser             @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  logs             WorkerDocumentLog[]

  @@index([workerId])
  @@map("worker_documents")
}

model WorkerDocumentLog {
  id               String         @id @default(uuid())
  workerDocumentId String         @map("worker_document_id")
  actorUserId      String         @map("actor_user_id")
  action           String
  oldValue         Json?          @map("old_value")
  newValue         Json?          @map("new_value")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  workerDocument   WorkerDocument @relation(fields: [workerDocumentId], references: [id], onDelete: Cascade)
  actorUser        NewUser        @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([workerDocumentId])
  @@map("worker_document_logs")
}

// ============================================================
// WORKER ENGAGEMENT
// ============================================================

model WorkerEngagement {
  id                String             @id @default(uuid())
  workerId          String             @map("worker_id")
  organizationId    String             @map("organization_id")
  responsibleUserId String             @map("responsible_user_id")
  statusId          String             @map("status_id")
  type              EngagementType
  startDate         DateTime?          @map("start_date") @db.Date
  endDate           DateTime?          @map("end_date") @db.Date
  completedAt       DateTime?          @map("completed_at") @db.Timestamptz()
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  worker            Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responsibleUser   NewUser            @relation(fields: [responsibleUserId], references: [id], onDelete: Restrict)
  engagementStatus  OrganizationStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)
  issues            Issue[]
  auditLogs         WorkerAuditLog[]
  notifications     Notification[]

  @@index([workerId])
  @@index([organizationId])
  @@index([statusId])
  @@map("worker_engagements")
}

model WorkerAuditLog {
  id                 String           @id @default(uuid())
  workerEngagementId String           @map("worker_engagement_id")
  actorUserId        String           @map("actor_user_id")
  action             String
  oldValue           Json?            @map("old_value")
  newValue           Json?            @map("new_value")
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  workerEngagement   WorkerEngagement @relation(fields: [workerEngagementId], references: [id], onDelete: Cascade)
  actorUser          NewUser          @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([workerEngagementId])
  @@map("worker_audit_logs")
}

// ============================================================
// ISSUE TEMPLATES
// ============================================================

model IssueTemplate {
  id              String                 @id @default(uuid())
  organizationId  String                 @map("organization_id")
  createdByUserId String                 @map("created_by_user_id")
  name            String
  description     String?
  type            EngagementTemplateType
  isActive        Boolean                @default(true) @map("is_active")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy       NewUser                @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items           TemplateItem[]

  @@index([organizationId])
  @@map("issue_templates")
}

model TemplateItem {
  id              String             @id @default(uuid())
  issueTemplateId String             @map("issue_template_id")
  title           String
  description     String?
  defaultPriority DefaultPriority?   @map("default_priority")
  defaultStatus   DefaultIssueStatus @default(backlog) @map("default_status")
  orderIndex      Int                @default(0) @map("order_index")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  issueTemplate   IssueTemplate      @relation(fields: [issueTemplateId], references: [id], onDelete: Cascade)
  issues          Issue[]

  @@index([issueTemplateId])
  @@map("template_items")
}

// ============================================================
// ISSUES
// ============================================================

model Issue {
  id                 String             @id @default(uuid())
  workerEngagementId String             @map("worker_engagement_id")
  createdByUserId    String             @map("created_by_user_id")
  assigneeUserId     String?            @map("assignee_user_id")
  templateItemId     String?            @map("template_item_id")
  statusId           String             @map("status_id")
  title              String
  description        String?
  priority           IssuePriority      @default(no_priority)
  dueDate            DateTime?          @map("due_date") @db.Date
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  workerEngagement   WorkerEngagement   @relation(fields: [workerEngagementId], references: [id], onDelete: Cascade)
  createdBy          NewUser            @relation("IssueCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignee           NewUser?           @relation("IssueAssignedTo", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  templateItem       TemplateItem?      @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  issueStatus        OrganizationStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)
  comments           Comment[]
  auditLogs          IssueAuditLog[]
  notifications      Notification[]
  labels             IssueLabel[]

  @@index([workerEngagementId])
  @@index([assigneeUserId])
  @@index([statusId])
  @@map("issues")
}

model IssueLabel {
  issueId   String @map("issue_id")
  labelId   String @map("label_id")

  // relations
  issue     Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  label     Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
  @@map("issue_labels")
}

model IssueAuditLog {
  id          String   @id @default(uuid())
  issueId     String   @map("issue_id")
  actorUserId String   @map("actor_user_id")
  action      String
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorUser   NewUser  @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([issueId])
  @@map("issue_audit_logs")
}

model Comment {
  id              String    @id @default(uuid())
  issueId         String    @map("issue_id")
  userId          String    @map("user_id")
  parentCommentId String?   @map("parent_comment_id")
  body            String
  editedAt        DateTime? @map("edited_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  issue           Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user            NewUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentReplies")

  @@index([issueId])
  @@index([parentCommentId])
  @@map("comments")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  organizationId     String            @map("organization_id")
  workerEngagementId String?           @map("worker_engagement_id")
  issueId            String?           @map("issue_id")
  title              String
  body               String
  type               NotificationType
  isRead             Boolean           @default(false) @map("is_read")
  readAt             DateTime?         @map("read_at") @db.Timestamptz()
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  user               NewUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workerEngagement   WorkerEngagement? @relation(fields: [workerEngagementId], references: [id], onDelete: SetNull)
  issue              Issue?            @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@map("notifications")
}

// ============================================================
// SUBSCRIPTION & BILLING
// ============================================================

model Subscription {
  id                    String             @id @default(uuid())
  organizationId        String             @unique @map("organization_id")
  activePaymentMethodId String?            @unique @map("active_payment_method_id")
  plan                  SubscriptionPlan   @default(free)
  status                SubscriptionStatus @default(trialing)
  trialEndsAt           DateTime?          @map("trial_ends_at") @db.Timestamptz()
  currentPeriodStart    DateTime?          @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd      DateTime?          @map("current_period_end") @db.Timestamptz()
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activePaymentMethod   PaymentMethod?     @relation("ActivePaymentMethod", fields: [activePaymentMethodId], references: [id], onDelete: SetNull)
  paymentMethods        PaymentMethod[]    @relation("SubscriptionPaymentMethods")
  invoices              Invoice[]

  @@map("subscriptions")
}

model PaymentMethod {
  id                      String        @id @default(uuid())
  subscriptionId          String        @map("subscription_id")
  provider                String        @default("stripe")
  providerPaymentMethodId String        @map("provider_payment_method_id")
  cardBrand               String?       @map("card_brand")
  cardLast4               String?       @map("card_last4") @db.Char(4)
  cardExpMonth            Int?          @map("card_exp_month") @db.SmallInt
  cardExpYear             Int?          @map("card_exp_year") @db.SmallInt
  isActive                Boolean       @default(false) @map("is_active")
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt               DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  // relations
  subscription            Subscription  @relation("SubscriptionPaymentMethods", fields: [subscriptionId], references: [id], onDelete: Cascade)
  activeForSubscription   Subscription? @relation("ActivePaymentMethod")
  invoices                Invoice[]

  @@index([subscriptionId])
  @@map("payment_methods")
}

model Invoice {
  id                String        @id @default(uuid())
  paymentMethodId   String        @map("payment_method_id")
  subscriptionId    String        @map("subscription_id")
  providerInvoiceId String?       @map("provider_invoice_id")
  amountCents       Int           @map("amount_cents")
  currency          String        @default("USD")
  status            InvoiceStatus @default(draft)
  invoicePdfUrl     String?       @map("invoice_pdf_url")
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz()
  dueDate           DateTime?     @map("due_date") @db.Date
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  // relations
  paymentMethod     PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId])
  @@map("invoices")
}


// ENUMS


enum UserStatus {
  active
  inactive
  suspended
}

enum OrganizationSize {
  size_1_10     @map("1-10")
  size_11_50    @map("11-50")
  size_51_200   @map("51-200")
  size_201_500  @map("201-500")
  size_500_plus @map("500+")
}

enum OrganizationStatusEnum {
  active
  suspended
  deleted
}

enum MemberStatus {
  active
  inactive
  suspended
}

enum VerificationCodeType {
  email_verify
  password_reset
}

enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum WorkerStatus {
  active
  inactive
  archived
}

enum DocumentFileType {
  contract
  id
  certificate
  other
}

enum EngagementType {
  onboarding
  offboarding
  transfer
}

enum EngagementTemplateType {
  onboarding
  offboarding
  transfer
}

enum IssuePriority {
  urgent
  high
  medium
  low
  no_priority
}

enum DefaultPriority {
  urgent
  high
  medium
  low
}

enum DefaultIssueStatus {
  backlog
  todo
}

enum NotificationType {
  issue_assigned
  comment_added
  status_changed
  engagement_updated
}

enum SubscriptionPlan {
  free
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}



// Old Physical Data Model
model employee_forms {
  id           Int           @id @default(autoincrement())
  user_id      Int
  timestamp    DateTime?     @default(now()) @db.Timestamp(6)
  form_type    String
  worker_files WorkerFiles[]
  users        users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "employee_forms_users")
  form_inputs  form_inputs[]
}

model form_fields {
  form_field_id Int           @id @default(autoincrement())
  description   String?
  order_index   Int?
  timestamp     DateTime?     @default(now()) @db.Timestamp(6)
  owner         String        @default("cmknti1f800028tmmhf5u5627")
  template_type TemplateType?  @default(ONBOARDING)
  auth_user     User          @relation(fields: [owner], references: [id])
  form_inputs   form_inputs[]
}

model form_inputs {
  id               Int               @id @default(autoincrement())
  employee_form_id Int
  form_field_id    Int
  status           String?           @db.VarChar(55)
  edit             String?
  timestamp        DateTime?         @default(now()) @db.Timestamp(6)
  completed        Boolean           @default(false)
  HistoryFormData  HistoryFormData[]
  employee_forms   employee_forms    @relation(fields: [employee_form_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "form_inputs_employee_forms")
  form_fields      form_fields       @relation(fields: [form_field_id], references: [form_field_id], onDelete: Cascade, onUpdate: NoAction, map: "form_inputs_form_fields")
}

model users {
  id             Int              @id @default(autoincrement())
  email          String?          @unique @db.Citext
  adresse        String
  austrittsdatum DateTime?        @db.Date
  archivedAt     DateTime?        @db.Timestamp(6)
  archivedBy     String?
  createdAt      DateTime         @default(now()) @db.Timestamp(6)
  eintrittsdatum DateTime         @db.Date
  geburtsdatum   DateTime         @db.Date
  nachname       String
  position       String
  updatedAt      DateTime         @updatedAt @db.Timestamp(6)
  vorname        String
  archivedByUser User?            @relation("WorkerArchivedBy", fields: [archivedBy], references: [id], onDelete: SetNull)
  employee_forms employee_forms[]

  @@index([archivedAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime @default(dbgenerated("(now() + '30 days'::interval)"))
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model User {
  id                String             @id @default(cuid())
  vorname String  @db.VarChar(55) @default("TestVorname")
  nachname String @db.VarChar(55) @default("TestVorname")
  cloud_url String         @default("something")@db.VarChar(500) 
  email             String             @unique @db.Citext
  password          String
  verified          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user_permission   UserRole           @default(MITARBEITER)
  historyChanges    HistoryFormData[]
  sessions          Session[]
  verificationCodes VerificationCode[]
  owned_fields      form_fields[]
  employeeStatus    EmployeeStatus[]   @relation("absent_user")
  substituteFor     EmployeeStatus[]   @relation("substitute_user")
  archivedWorkers   users[]            @relation("WorkerArchivedBy")
}

model EmployeeStatus {
  id        Int      @id @default(autoincrement())
  userId String @unique
  absence String? 
  absencetype String?
  absencebegin DateTime?
  absenceEnd DateTime?
  substitute String?
  user      User     @relation("absent_user", fields: [userId], references: [id], onDelete: Cascade)
  sub_user     User?     @relation("substitute_user", fields: [substitute], references: [id])
  @@index([userId])
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  type      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HistoryFormData {
  id            Int         @id @default(autoincrement())
  form_input_id Int
  status        String?     @db.VarChar(55)
  edit          String?
  timestamp     DateTime?   @default(now()) @db.Timestamp(6)
  changed_by    String? 
  auth_user     User?        @relation(fields: [changed_by], references: [id])
  form_inputs   form_inputs @relation(fields: [form_input_id], references: [id], onDelete: Cascade)
}

model WorkerFiles {
  id                Int            @id @default(autoincrement())
  employee_form_id  Int
  original_filename String         @db.VarChar(255)
  file_size         Int
  content_type      String         @db.VarChar(100)
  cloud_url         String         @db.VarChar(500)
  cloud_key         String         @db.VarChar(500)
  uploaded_at       DateTime       @default(now())
  employee_forms    employee_forms @relation(fields: [employee_form_id], references: [id], onDelete: Cascade)
}

enum UserRole {
  MITARBEITER
  CHEF
}

enum TemplateType {
  ONBOARDING
  OFFBOARDING
}
